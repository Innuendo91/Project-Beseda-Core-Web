# Run install.sh to generate this file with secure secrets!
NODE_ENV=production
PORT=4001

# Must match stream-app/.env
VOICE_JWT_SECRET=GENERATE_ME_64_CHARS_HEX
VOICE_SERVER_SECRET=GENERATE_ME_64_CHARS_HEX

# Public IP of this server (IMPORTANT for WebRTC)
ANNOUNCED_IP=YOUR_PUBLIC_IP

# UDP range for mediasoup
RTP_MIN_PORT=40000
RTP_MAX_PORT=40100

# URL of stream-app for DB cleanup callbacks
STREAM_APP_URL=http://stream-app:8085

# Delay before auto-deleting empty non-permanent rooms (ms)
ROOM_CLEANUP_DELAY_MS=300000
