# Run install.sh to generate this file with secure secrets!
# This is a template only — values below are NOT secure.

PORT=8085

# Bootstrap admin (one-time: creates admin user on first startup, then safe to remove)
# ADMIN_BOOTSTRAP_USER=admin
# ADMIN_BOOTSTRAP_PASS=strongpassword

# Session
SESSION_SECRET=GENERATE_ME_64_CHARS_HEX

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL
DB_HOST=postgres
DB_USER=streamapp
DB_PASS=GENERATE_ME_32_CHARS_HEX
DB_NAME=streamapp

# Registration
REGISTRATION_CODE=GENERATE_ME_16_CHARS_HEX

# WHEP playback (browser → MediaMTX)
STREAM_HOST=your.domain.com
WHEP_PORT=8889
WHEP_JWT_SECRET=GENERATE_ME_64_CHARS_HEX

# MediaMTX Control API
MEDIAMTX_API_HOST=mediamtx
MEDIAMTX_API_PORT=9997
MEDIAMTX_API_USER=api
MEDIAMTX_API_PASS=GENERATE_ME_48_CHARS_HEX

# SRT ingest
SRT_INGEST_HOST=YOUR_PUBLIC_IP_OR_DOMAIN
SRT_INGEST_PORT=8890
SRT_LATENCY=300000
SRT_PASSPHRASE=GENERATE_ME
SRT_PBKEYLEN=32

# Voice (must match voice-server/.env)
VOICE_JWT_SECRET=GENERATE_ME_64_CHARS_HEX
VOICE_SERVER_URL=ws://voice-server:4001
VOICE_SERVER_SECRET=GENERATE_ME_64_CHARS_HEX

# Base URL
BASE_URL=https://your.domain.com
