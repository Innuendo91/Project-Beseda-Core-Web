<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="theme-color" content="#101114" />
  <title><%= siteName || "Stream" %></title>
  <link rel="manifest" href="/public/manifest.json" />
  <link rel="icon" type="image/png" href="/public/logo.png" />
  <link rel="stylesheet" href="/public/css/base.css" />
  <link rel="stylesheet" href="/public/css/components.css" />
  <link rel="stylesheet" href="/public/css/pages.css" />
  <link rel="stylesheet" href="/public/css/voice.css" />
  <link rel="stylesheet" href="/public/css/admin.css" />
  <link rel="stylesheet" href="/public/css/responsive.css" />
  <link rel="stylesheet" href="/public/spa/assets/index.css" />
</head>
<body>
  <div id="app"></div>
  <script>
    window.__CSRF__ = { token: <%- JSON.stringify(csrfToken || "") %> };
    window.__APP__ = {
      user: <%- JSON.stringify(user || null) %>,
      isAdmin: <%- JSON.stringify(!!isAdmin) %>,
      siteName: <%- JSON.stringify(siteName || "Stream") %>,
      siteSubtitle: <%- JSON.stringify(siteSubtitle || "") %>
    };
  </script>
  <script type="module" src="/public/spa/assets/index.js"></script>
</body>
</html>
